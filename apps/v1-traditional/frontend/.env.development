# 账号中心 - 测试环境
NEXT_PUBLIC_SSO_URL=https://iam-test.haier.net
# 新项目可使用 S 码；旧项目必须使用 clientId
# 获取地址：https://e.haier.net/new-e/console/iam-admin
NEXT_PUBLIC_CLIENT_ID=2d878ed8aadf3f6eff21a4d7269f02f2
# 直接向后端索取 Token 接口地址
NEXT_PUBLIC_TOKEN_URL=/iam-proxy/getTokenAndUserInfo
# 飞书 ID，用于 ihaier H5 登录（PC 端可留空）
NEXT_PUBLIC_APP_ID=

# 后端 API 地址
NEXT_PUBLIC_API_URL=http://localhost:3101

# 战投平台后端（项目列表等）— 测试环境（前端不直接用，走后端代理）
# NEXT_PUBLIC_PLATFORM_BACKEND_URL=http://10.138.68.2:30302
